# .env.example
# Copy to .env and fill in for local development:
#   cp .env.example .env

# --- Backend (backend/app/config.py) ---
MODEL_CHECKPOINT=artifacts/best_model.pt
REFERENCE_MODEL_PATH=artifacts/reference/model.joblib
DEVICE=cpu
CORS_ORIGINS=*
MAX_BATCH_SIZE=64
LOG_LEVEL=INFO

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Frontend (frontend/dashboard-react) ---
VITE_API_BASE_URL=http://localhost:8000
